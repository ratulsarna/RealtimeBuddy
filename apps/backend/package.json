{
  "name": "@realtimebuddy/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bootstrap.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "node --import tsx src/bootstrap.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts' -print)"
  },
  "dependencies": {
    "@realtimebuddy/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
